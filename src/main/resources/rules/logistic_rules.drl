package rules;
//generated from Decision Table
import com.example.droolsengine.Logistics;
import com.example.droolsengine.DeliveryCountry;
import com.example.droolsengine.DeliveryType;
// rule values at A9, header at A4
rule "Delivery AR 0kg < x <= 60kg"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.AR), $logistics.getWeight > (0), $logistics.getWeight <= (60))
	then
		$logistics.setDeliveryType(DeliveryType.STANDARD_MAIL); drools.halt();
end

// rule values at A10, header at A4
rule "Delivery AR 60kg < x <= 500kg"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.AR), $logistics.getWeight > (60), $logistics.getWeight <= (500))
	then
		$logistics.setDeliveryType(DeliveryType.SPECIAL_FREIGHT); drools.halt();
end

// rule values at A11, header at A4
rule "Delivery AR > 500kg"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.AR), $logistics.getWeight > (500))
	then
		$logistics.setDeliveryType(DeliveryType.MANUAL_REVIEW); drools.halt();
end

// rule values at A12, header at A4
rule "Delivery JP 0kg < x <= 200kg"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.JP), $logistics.getWeight > (0), $logistics.getWeight <= (200))
	then
		$logistics.setDeliveryType(DeliveryType.AIR_FREIGHT); drools.halt();
end

// rule values at A13, header at A4
rule "Delivery RU any weight"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.RU))
	then
		$logistics.setDeliveryType(DeliveryType.MANUAL_REVIEW); drools.halt();
end

// rule values at A14, header at A4
rule "Delivery CH any weight"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.CH), $logistics.getWeight > (0))
	then
		$logistics.setDeliveryType(DeliveryType.STANDARD_FREIGHT); drools.halt();
end

// rule values at A15, header at A4
rule "Delivery DE any weight"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.DE), $logistics.getWeight > (0))
	then
		$logistics.setDeliveryType(DeliveryType.STANDARD_FREIGHT); drools.halt();
end

// rule values at A16, header at A4
rule "Delivery no available Country"
	when
		$logistics:Logistics($logistics.getDestination() in (DeliveryCountry.NOT_DEFINED))
	then
		$logistics.setDeliveryType(DeliveryType.MANUAL_REVIEW); drools.halt();
end

// rule values at A17, header at A4
rule "Delivery Fallback"
	salience -1000
	when
		$logistics:Logistics($logistics.getDeliveryType() == (null))
	then
		$logistics.setDeliveryType(DeliveryType.MANUAL_REVIEW); drools.halt();
end

